{
  "vaults": [
    {
      "name": "work",
      "path": "X:\\Obsidian Vaults\\Work",
      "enableWrite": true
    },
    {
      "name": "personal",
      "path": "X:\\Obsidian Vaults\\Personal",
      "enableWrite": false
    }
  ],
  "includePatterns": ["**/*.md"],
  "excludePatterns": [
    "_archive/**",
    ".obsidian/**",
    ".trash/**",
    "node_modules/**",
    "**/node_modules/**",
    ".git/**",
    "_assets/**"
  ],
  "enableWrite": false,
  "vectorSearch": {
    "enabled": true,
    "provider": "transformers",
    "model": "Xenova/bge-small-en-v1.5",
    "indexOnStartup": "auto"
  },
  "searchOptions": {
    "maxResults": 20,
    "excerptLength": 200,
    "caseSensitive": false,
    "includeMetadata": true
  },
  "logging": {
    "level": "info",
    "file": "logs/mcp-server.log"
  }
}
